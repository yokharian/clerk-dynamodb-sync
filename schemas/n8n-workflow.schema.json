{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "n8n Workflow (pragmatic)",
  "type": "object",
  "required": ["name", "nodes", "connections", "settings"],
  "properties": {
    "id": { "type": ["string", "number"] },
    "name": { "type": "string", "minLength": 1 },
    "active": { "type": "boolean" },
    "versionId": { "type": "string" },
    "meta": { "type": "object", "additionalProperties": true },
    "tags": { "type": "array", "items": { "type": ["string", "object"] } },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "parameters", "position"],
        "properties": {
          "id": { "type": ["string", "number"] },
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "typeVersion": { "type": "number" },
          "parameters": { "type": "object", "additionalProperties": true },
          "position": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 2,
            "maxItems": 2
          },
          "credentials": { "type": "object", "additionalProperties": true },
          "disabled": { "type": "boolean" },
          "notesInFlow": { "type": "boolean" },
          "continueOnFail": { "type": "boolean" },
          "onError": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "connections": { "type": "object", "additionalProperties": true },
    "settings": { "type": "object", "additionalProperties": true },
    "staticData": { "type": "object", "additionalProperties": true },
    "pinData": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": true
}





